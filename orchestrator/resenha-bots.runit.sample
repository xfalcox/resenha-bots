#!/bin/bash
# runit service script. Copied to /etc/service/resenha-bots/run by an app.yml
# hook so runit supervises and auto-restarts the orchestrator.
#
# Secrets / site config are NOT set here — they come from the container
# environment, which you set in the app.yml `env:` block (persists across
# rebuilds, unlike editing this file in place). The daemon reads:
#   SITE_URL                   e.g. https://your-demo-site.example.com
#   RESENHA_BOTS_API_KEY       an admin API key
#   RESENHA_BOTS_API_USERNAME  defaults to "system" if unset
#
# `exec 2>&1` routes logs to the container log; `chpst -u` runs as the discourse
# user while preserving the inherited environment (so the env: vars pass through).

exec 2>&1

# Fixed paths — safe to hardcode. Keep the browser + audio cache in /shared so
# they survive container rebuilds.
export PLAYWRIGHT_BROWSERS_PATH=/shared/resenha-bots/ms-playwright
export RESENHA_BOTS_AUDIO_DIR=/shared/resenha-bots/audio

cd /var/www/discourse/plugins/resenha-bots/orchestrator
exec chpst -u discourse:discourse node index.js
